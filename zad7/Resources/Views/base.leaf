<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>#import("title")</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
        nav { margin-bottom: 1rem; }
        nav a { margin-right: 1rem; text-decoration: none; color: #333; }
        table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
        th, td { border: 1px solid #ccc; padding: 0.5rem 1rem; text-align: left; }
        th { background: #f5f5f5; }
        input, textarea { width: 100%; padding: 0.4rem; margin-top: 0.2rem; box-sizing: border-box; }
        .btn { padding: 0.4rem 1rem; cursor: pointer; background: #333; color: white; border: none; border-radius: 4px; text-decoration: none; }
        .btn-danger { background: #cc3333; }
        .btn-secondary { background: #888; }
    </style>
</head>
<body>
    <nav>
        <a href="/products">Produkty</a>
        <a href="/categories">Kategorie</a>
    </nav>
    <hr>
    #import("body")
</body>
</html>